<config>
  
  <devices>
    
    <entry name="localhost.domain">

      <vsys>
        
        <entry name="vsys1">
          
          <rulebase>
            
            <security>
              
              <rules>
                
                <entry name="Allow Web">
                  <description>Allow users to access the internet</description>
                  <source>
                    <member>Internal</member>
                  </source>
                  <destination>
                    <member>Internet</member>
                  </destination>
                  <application>
                    <member>web-browsing</member>
                  </application>
                  <disabled>no</disabled>
                  <log-end>yes</log-end>
                </entry>
                
                <entry name="Allow DNS">
                  <source>
                    <member>Internal</member>
                  </source>
                  <destination>
                    <member>dns-server</member>
                  </destination>
                  <application>
                    <member>dns</member>
                  </application>
                  <disabled>no</disabled>
                  <log-end>yes</log-end>
                </entry>
                
                <entry name="Restricted Internet Access">
                  <description>Restricted Internet Access</description>
                  <source>
                    <member>Internal</member>
                  </source>
                  <destination>
                    <member>Social Media</member>
                  </destination>
                  <application>
                    <member>web-browsing</member>
                  </application>
                  <disabled>no</disabled>
                  <log-end>yes</log-end>
                </entry>

                <entry name="Test Rule">
                  <description>This is a test rule</description>
                  <source>
                    <member>Internal</member>
                  </source>
                  <destination>
                    <member>Internet</member>
                  </destination>
                  <application>
                    <member>web-browsing</member>
                  </application>
                  <disabled>no</disabled>
                  <log-end>yes</log-end>  
                </entry>
                
                <entry name="Test Rule 2">
                  <description>This is test rule 2</description>
                  <source>
                    <member>Internal</member>
                  </source>
                  <destination>
                    <member>Internet</member>
                  </destination>
                  <application>
                    <member>web-browsing</member>
                  </application>
                  <disabled>yes</disabled>
                  <log-end>yes</log-end>  
                </entry>

                <entry name="Any Any Rule">
                  <description>Any Any Rule</description>
                  <source>
                    <member>any</member>
                  </source>
                  <destination>
                    <member>any</member>
                  </destination>
                  <application>
                    <member>any</member>
                  </application>
                  <disabled>no</disabled>
                  <log-end>yes</log-end>
                </entry>

              </rules>
              
            </security>
            
          </rulebase>
          
        </entry>
        
      </vsys>
      
    </entry>
    
  </devices>
  
</config>  
