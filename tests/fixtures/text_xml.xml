<config>

  <devices>

    <entry name="localhost.domain">

      <vsys>

        <entry name="vsys1">

          <rulebase>

            <security>

              <rules>

                <entry name="Any Any Rule">
                  <source>
                    <member>any</member>
                  </source>
                  <destination>
                    <member>any</member>
                  </destination>
                  <application>
                    <member>any</member>
                  </application>
                  <disabled>no</disabled>
                  <log-end>yes</log-end>
                </entry>
                <entry name="Allow DNS">
                </entry>
                <entry name="Good Rule">
                  <description>
                    This is a good rule
                  </description>
                  <source>
                    <member>Internal</member>
                  </source>
                  <destination>
                    <member>Internet</member>
                  </destination>
                  <application>
                    <member>web-browsing</member>
                  </application>
                  <disabled>no</disabled>
                  <log-end>yes</log-end>
                </entry>
              </rules>

            </security>

          </rulebase>

        </entry>

      </vsys>

    </entry>

  </devices>

</config>
